{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Crab Rustler: session bootstrap reminder",
      "type": "shell",
      "command": "bash",
      "args": [
        "-c",
        "echo ''; echo '🦀 Crab Rustler session ready.'; echo '   Tell Claude Code: \"bootstrap\" to start the game-dev loop, release judge, and Slack crons.'; echo '   (See CLAUDE.md for the full bootstrap instructions.)'; echo ''"
      ],
      "runOptions": {
        "runOn": "folderOpen"
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "showReuseMessage": false
      },
      "isBackground": false,
      "problemMatcher": []
    },
    {
      "label": "Crab Rustler: run game",
      "type": "shell",
      "command": "nix",
      "args": [
        "develop",
        "/home/carl/Repos/carlthome/rustler",
        "--command",
        "./target/debug/rustler"
      ],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated"
      },
      "problemMatcher": []
    },
    {
      "label": "Crab Rustler: build",
      "type": "shell",
      "command": "nix",
      "args": [
        "develop",
        "/home/carl/Repos/carlthome/dotfiles#rustler",
        "--command",
        "cargo",
        "build"
      ],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": ["$rustc"]
    }
  ]
}

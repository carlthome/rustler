{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Crab Rustler: run game",
      "type": "shell",
      "command": "nix",
      "args": [
        "develop",
        "${workspaceFolder}",
        "--command",
        "./target/debug/rustler"
      ],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated"
      },
      "problemMatcher": []
    },
    {
      "label": "Crab Rustler: build",
      "type": "shell",
      "command": "nix",
      "args": [
        "develop",
        "${workspaceFolder}",
        "--command",
        "cargo",
        "build"
      ],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": ["$rustc"]
    }
  ]
}
